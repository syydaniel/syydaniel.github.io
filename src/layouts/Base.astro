---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Arcade from '../components/Arcade.astro';
import Cursor from '../components/Cursor.astro';
import GradCelebration from '../components/GradCelebration.astro';

interface Props {
  title?: string;
  description?: string;
  /** Path or absolute URL to the social share image. */
  image?: string;
  /** 'website' (default) or 'article' for journal posts. */
  type?: 'website' | 'article';
  /** ISO date, emitted as article:published_time when type is 'article'. */
  publishedTime?: string;
  /** Keep this page out of search engines (e.g. drafts). */
  noindex?: boolean;
}

const {
  title = 'Yiyang Shen · MSc & Photographer',
  description = 'Personal site of Yiyang Shen (Daniel, 沈亦旸). MSc in Urban Environmental Management from Wageningen University & Research, graduated May 2026, with a thesis on water systems and microplastics and a photography archive from four countries.',
  image = '/og-image.jpg',
  type = 'website',
  publishedTime,
  noindex = false
} = Astro.props;

const site = Astro.site ?? new URL('https://syydaniel.github.io');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image, site).href;

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Yiyang Shen',
  alternateName: ['Daniel', '沈亦旸'],
  url: site.href,
  image: ogImage,
  jobTitle: 'MSc, Urban Environmental Management',
  alumniOf: [{ '@type': 'CollegeOrUniversity', name: 'Wageningen University & Research' }],
  knowsAbout: ['Water systems', 'Microplastics', 'Urban sustainability', 'Photography'],
  sameAs: [
    'https://www.linkedin.com/in/yiyang-shen-%E6%B2%88%E4%BA%A6%E6%97%B8-05502821b/',
    'https://github.com/syydaniel'
  ]
};
const siteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Yiyang Shen',
  url: site.href
};
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#05060a" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Yiyang Shen" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="zh_CN" />
    <meta property="og:locale:alternate" content="zh_TW" />
    <meta property="og:locale:alternate" content="nl_NL" />
    <meta property="og:locale:alternate" content="de_DE" />
    {type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Yiyang Shen · Journal" href="/rss.xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(siteLd)} />
  </head>
  <body class="ambient-noise min-h-screen">
    <div class="aurora" aria-hidden="true"></div>
    <div id="page-reveal" class="fixed inset-0 z-[500] bg-ink-950 pointer-events-none"></div>
    <Cursor />
    <Nav />
    <main class="relative z-10">
      <slot />
    </main>
    <Footer />
    <Arcade />
    <GradCelebration />

    <script>
      import '../scripts/i18n-runtime';

      const revealObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));

      // page entry reveal
      requestAnimationFrame(() => {
        document.getElementById('page-reveal')?.animate(
          [
            { opacity: 1, transform: 'scaleY(1)' },
            { opacity: 1, transform: 'scaleY(0)', transformOrigin: 'top' }
          ],
          { duration: 900, easing: 'cubic-bezier(0.7, 0, 0.2, 1)', fill: 'forwards' }
        );
      });
    </script>
  </body>
</html>
