---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '../../data/reading-time';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Base
  title="Journal · Yiyang Shen"
  description="Field notes and short essays on water, microplastics, and photography by Yiyang Shen (沈亦旸)."
>
  <section class="mx-auto max-w-5xl px-6 pt-32 md:pt-40 pb-28">
    <a href="/" class="inline-flex items-center gap-2 text-sm text-ink-400 hover:text-aqua-300 transition-colors">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      <span data-i18n="blog.backhome">Home</span>
    </a>

    <div class="mt-8">
      <span class="section-eyebrow" data-i18n="blog.eyebrow">Journal</span>
      <h1 class="section-title mt-4" data-i18n="blog.title">Field notes & essays</h1>
      <p class="mt-5 text-ink-300 max-w-2xl" data-i18n="blog.intro">
        Short notes from the water and microplastics work, the occasional photo essay, and
        things I am still thinking about. Written in English and 中文.
      </p>
    </div>

    <div id="blog-empty" class="hidden mt-8 glass-soft rounded-xl px-4 py-3 text-sm text-ink-400" data-i18n="blog.empty">
      No posts in this language yet. Showing everything.
    </div>

    {posts.length === 0 ? (
      <p class="mt-12 text-ink-400" data-i18n="blog.none">No posts yet. Check back soon.</p>
    ) : (
      <div id="post-grid" class="mt-12 grid gap-6 md:grid-cols-2">
        {posts.map((p) => <PostCard post={p} minutes={readingTime(p.body ?? '', p.data.lang)} />)}
      </div>
    )}
  </section>

  <script>
    function detectLang(): string {
      const stored = localStorage.getItem('site-lang');
      if (stored === 'en' || stored === 'zh') return stored;
      const getLang = (window as any).__getLang;
      if (typeof getLang === 'function') return getLang();
      return (navigator.language || '').toLowerCase().startsWith('zh') ? 'zh' : 'en';
    }
    function applyBlogLang() {
      const grid = document.getElementById('post-grid');
      const empty = document.getElementById('blog-empty');
      if (!grid) return;
      const lang = detectLang();
      const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-lang]'));
      const inLang = cards.filter((c) => c.dataset.lang === lang);
      const visible = inLang.length ? inLang : cards;
      cards.forEach((c) => { c.style.display = visible.includes(c) ? '' : 'none'; });
      if (empty) empty.classList.toggle('hidden', inLang.length > 0);
    }
    applyBlogLang();
    window.addEventListener('lang:change', applyBlogLang);
  </script>
</Base>
