---
import PostLayout from '../../layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';
import { readingTime } from '../../data/reading-time';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post, posts }
  }));
}

const { post, posts } = Astro.props;
const { Content } = await render(post);
const minutes = readingTime(post.body ?? '', post.data.lang);
const translation = post.data.translationKey
  ? posts.find((p) => p.data.translationKey === post.data.translationKey && p.id !== post.id)
  : undefined;
---

<PostLayout post={post} minutes={minutes} translation={translation}>
  <Content />
</PostLayout>
