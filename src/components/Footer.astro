---
import { profile } from '../data/profile';
const year = new Date().getFullYear();
---

<footer class="relative z-10 mt-32 border-t border-white/5 bg-gradient-to-b from-transparent to-ink-950/60">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
      <div>
        <p class="font-display text-3xl md:text-4xl text-ink-100 leading-tight max-w-md">
          <span data-i18n="footer.title.a">Let's collaborate on</span> <span class="text-gradient" data-i18n="footer.title.b">water, change, and the world we photograph</span>.
        </p>
        <p class="mt-4 text-ink-300 text-sm">
          {profile.location} · <span data-i18n="footer.location_hint">Available for research collaborations and editorial photo use.</span>
        </p>
      </div>
      <div class="flex flex-col gap-2 md:items-end">
        <div class="flex gap-3">
          {
            profile.socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noreferrer"
                aria-label={s.label}
                class="w-10 h-10 rounded-full glass-soft flex items-center justify-center text-ink-200 hover:text-aqua-400 hover:border-aqua-400/40 transition-colors"
              >
                {s.icon === 'linkedin' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
                )}
                {s.icon === 'github' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2A10 10 0 002 12.26a10 10 0 006.84 9.53c.5.1.68-.22.68-.48v-1.7c-2.79.62-3.37-1.22-3.37-1.22a2.65 2.65 0 00-1.11-1.47c-.91-.62.07-.6.07-.6a2.11 2.11 0 011.54 1.05 2.16 2.16 0 002.94.83 2.14 2.14 0 01.64-1.34c-2.23-.26-4.57-1.12-4.57-4.97a3.88 3.88 0 011.04-2.7 3.63 3.63 0 01.1-2.66s.85-.27 2.78 1.03a9.57 9.57 0 015.06 0c1.93-1.3 2.78-1.03 2.78-1.03a3.63 3.63 0 01.1 2.66 3.88 3.88 0 011.04 2.7c0 3.87-2.34 4.71-4.58 4.96a2.4 2.4 0 01.68 1.86v2.76c0 .27.18.58.69.48A10 10 0 0022 12.26 10 10 0 0012 2z"/></svg>
                )}
                {s.icon === 'mail' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                )}
              </a>
            ))
          }
        </div>
        <p class="text-xs text-ink-400" data-i18n="footer.rights" data-i18n-vars={JSON.stringify({ year })}>
          © {year} Yiyang Shen · Built with Astro
        </p>
      </div>
    </div>
  </div>
</footer>
