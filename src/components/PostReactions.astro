---
// Per-post "like" using the same free, CORS-enabled Abacus counter the
// graduation ribbon uses. Cross-visitor, no backend. One like per browser.
interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<div class="post-reactions mt-12 flex items-center gap-3" data-slug={slug}>
  <button
    type="button"
    class="like-btn inline-flex items-center gap-2 rounded-full px-4 py-2 glass hover:border-aqua-400/40 transition-colors"
    aria-label="Like this post"
  >
    <svg class="like-heart" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
    </svg>
    <span class="like-count font-mono tabular-nums">0</span>
  </button>
  <span class="text-sm text-ink-400" data-i18n="blog.like_hint">Like this if it resonated.</span>
</div>

<style>
  .like-heart { fill: none; stroke: #ff7a8a; stroke-width: 2; transition: fill .2s ease, transform .2s ease; }
  .like-btn:hover .like-heart { transform: scale(1.12); }
  .like-btn.liked .like-heart { fill: #ff5a6a; stroke: #ff5a6a; }
  .like-btn.liked { cursor: default; }
</style>

<script>
  const API = 'https://abacus.jasoncameron.dev';
  const NS = 'syydaniel-portfolio';
  document.querySelectorAll<HTMLElement>('.post-reactions').forEach((root) => {
    const slug = root.dataset.slug;
    if (!slug) return;
    const counter = 'post-' + slug;
    const btn = root.querySelector<HTMLButtonElement>('.like-btn');
    const num = root.querySelector<HTMLElement>('.like-count');
    if (!btn || !num) return;
    const cacheKey = 'like_' + counter;
    const likedKey = 'liked_' + counter;
    const fmt = (n: number) => n.toLocaleString();
    let val = parseInt(localStorage.getItem(cacheKey) || '0', 10);
    if (!Number.isFinite(val) || val < 0) val = 0;
    num.textContent = fmt(val);
    if (localStorage.getItem(likedKey)) btn.classList.add('liked');

    const apply = (v: number | null) => {
      if (v == null || !Number.isFinite(v)) return;
      if (v >= val) {
        val = v;
        num.textContent = fmt(val);
        try { localStorage.setItem(cacheKey, String(v)); } catch (e) {}
      }
    };
    const parse = (d: any): number | null => {
      if (!d) return null;
      const v = typeof d.value === 'number' ? d.value : Number(d.value);
      return Number.isFinite(v) ? v : null;
    };

    fetch(`${API}/get/${NS}/${counter}`, { cache: 'no-store' })
      .then((r) => (r.ok ? r.json() : null)).then((d) => apply(parse(d))).catch(() => {});

    btn.addEventListener('click', () => {
      if (localStorage.getItem(likedKey)) return;
      try { localStorage.setItem(likedKey, '1'); } catch (e) {}
      btn.classList.add('liked');
      val++;
      num.textContent = fmt(val);
      try { localStorage.setItem(cacheKey, String(val)); } catch (e) {}
      fetch(`${API}/hit/${NS}/${counter}`, { cache: 'no-store' })
        .then((r) => (r.ok ? r.json() : null)).then((d) => apply(parse(d))).catch(() => {});
    });
  });
</script>
