---
// Global floating graduation-celebration ribbon with a like counter.
// The ribbon drifts freely across the page (kept below the fixed nav so it is
// never occluded). Clicking it "likes" the milestone: the count persists in
// localStorage, with a rising "+1", a heart/confetti particle burst, a count
// pop, and a toast that shows the accumulating total. Bilingual via i18n.
---

<div class="gc-root" id="gc-root" aria-live="off">
  <button class="gc-ribbon" id="gc-ribbon" type="button" aria-label="Celebrate this graduation">
    <span class="gc-text" data-i18n="hero.gradbanner">Celebrating my MSc graduation!</span>
    <span class="gc-like">
      <svg class="gc-heart" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      <span class="gc-num" id="gc-num">0</span>
    </span>
  </button>
</div>
<div class="gc-fx" id="gc-fx" aria-hidden="true"></div>
<div class="gc-toast" id="gc-toast" role="status" aria-hidden="true"></div>

<style is:global>
  .gc-root{position:fixed;top:0;left:0;z-index:45;width:max-content;pointer-events:none;will-change:transform;}
  .gc-ribbon{
    pointer-events:auto;display:inline-flex;align-items:center;gap:.7rem;
    padding:.5rem 1.5rem;border:0;cursor:pointer;font-family:inherit;font-weight:700;
    font-size:.92rem;letter-spacing:.03em;color:#fff;white-space:nowrap;
    background:linear-gradient(135deg,#ff4646 0%,#e01b2b 48%,#a8101b 100%);
    clip-path:polygon(0 0,100% 0,calc(100% - 13px) 50%,100% 100%,0 100%,13px 50%);
    box-shadow:0 12px 32px -10px rgba(216,24,40,.75),inset 0 1px 0 rgba(255,255,255,.3);
    text-shadow:0 1px 2px rgba(0,0,0,.28);transform-origin:center;
    animation:gc-flutter 3.8s ease-in-out infinite;transition:filter .2s ease;
  }
  .gc-ribbon:hover{filter:brightness(1.08) saturate(1.08);}
  .gc-ribbon:focus-visible{outline:2px solid #fff;outline-offset:3px;}
  @keyframes gc-flutter{
    0%,100%{transform:rotate(-2.4deg) skewX(0) translateY(0);}
    25%{transform:rotate(-1.1deg) skewX(2deg) translateY(-3px);}
    50%{transform:rotate(-2.4deg) skewX(0) translateY(2px);}
    75%{transform:rotate(-3.7deg) skewX(-2deg) translateY(-2px);}
  }
  .gc-like{display:inline-flex;align-items:center;gap:.3rem;padding-left:.65rem;border-left:1px solid rgba(255,255,255,.4);}
  .gc-heart{width:15px;height:15px;fill:#fff;filter:drop-shadow(0 0 4px rgba(255,255,255,.55));}
  .gc-num{font-variant-numeric:tabular-nums;min-width:1ch;display:inline-block;}
  .gc-num.gc-pop{animation:gc-pop .45s cubic-bezier(.2,1.5,.4,1);}
  @keyframes gc-pop{0%{transform:scale(1);}35%{transform:scale(1.6);text-shadow:0 0 12px rgba(255,255,255,.95);}100%{transform:scale(1);}}
  .gc-fx{position:fixed;inset:0;z-index:60;pointer-events:none;overflow:hidden;}
  .gc-plus{position:absolute;transform:translate(-50%,-50%);font-weight:800;font-size:1.05rem;display:flex;align-items:center;gap:3px;white-space:nowrap;text-shadow:0 2px 10px rgba(255,40,60,.55);}
  .gc-plus svg{width:15px;height:15px;fill:currentColor;}
  .gc-particle{position:absolute;transform:translate(-50%,-50%);border-radius:50%;}
  .gc-particle svg{width:100%;height:100%;fill:currentColor;display:block;}
  .gc-toast{
    position:fixed;left:50%;bottom:2rem;transform:translate(-50%,150%);z-index:60;pointer-events:none;
    display:flex;align-items:center;gap:.55rem;padding:.7rem 1.25rem;border-radius:999px;
    background:rgba(22,7,11,.74);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
    border:1px solid rgba(255,90,90,.45);color:#fff;font-weight:600;font-size:.9rem;
    box-shadow:0 16px 44px -12px rgba(216,24,40,.6);opacity:0;
    transition:transform .55s cubic-bezier(.2,1,.3,1),opacity .4s ease;
  }
  .gc-toast.gc-show{transform:translate(-50%,0);opacity:1;}
  .gc-toast svg{width:18px;height:18px;fill:#ff5a5a;flex:none;}
  .gc-toast strong{font-variant-numeric:tabular-nums;}
  @media (max-width:640px){.gc-ribbon{font-size:.78rem;padding:.42rem 1.1rem;gap:.5rem;}}
  @media (prefers-reduced-motion:reduce){.gc-ribbon{animation:none;}}
</style>

<script>
  const HEART = 'M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z';
  const svg = (cls) => `<svg class="${cls || ''}" viewBox="0 0 24 24"><path d="${HEART}"/></svg>`;

  const root = document.getElementById('gc-root');
  const ribbon = document.getElementById('gc-ribbon');
  const numEl = document.getElementById('gc-num');
  const fx = document.getElementById('gc-fx');
  const toast = document.getElementById('gc-toast');

  if (root && ribbon && numEl && fx && toast) {
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    // Shared cross-visitor counter via the Abacus free counter API (no auth,
    // CORS-enabled), cached in localStorage for instant paint + offline fallback.
    const API = 'https://abacus.jasoncameron.dev';
    const NS = 'syydaniel-portfolio';
    const COUNTER = 'grad-likes';
    const CACHE = 'gc_grad_likes_v2';
    const fmt = (n) => n.toLocaleString();
    let likes = parseInt(localStorage.getItem(CACHE) || '0', 10);
    if (!Number.isFinite(likes) || likes < 0) likes = 0;
    numEl.textContent = fmt(likes);

    const parseVal = (d) => {
      if (!d) return null;
      const v = typeof d.value === 'number' ? d.value : Number(d.value);
      return Number.isFinite(v) ? v : null;
    };
    const applyServer = (v) => {
      if (v == null) return;
      try { localStorage.setItem(CACHE, String(v)); } catch (e) {}
      if (v > likes) { likes = v; numEl.textContent = fmt(likes); }
    };
    const syncGet = () => fetch(`${API}/get/${NS}/${COUNTER}`, { cache: 'no-store' })
      .then((r) => (r.ok ? r.json() : null)).then((d) => applyServer(parseVal(d))).catch(() => {});
    const sendHit = () => fetch(`${API}/hit/${NS}/${COUNTER}`, { cache: 'no-store' })
      .then((r) => (r.ok ? r.json() : null)).then((d) => applyServer(parseVal(d))).catch(() => {});
    syncGet();
    setInterval(() => { if (!document.hidden) syncGet(); }, 30000);
    window.addEventListener('focus', syncGet);

    // ---------- free drift, kept below the nav ----------
    let raf = 0;
    const drift = (now) => {
      const t = now / 1000;
      const vw = innerWidth, vh = innerHeight;
      const rw = ribbon.offsetWidth, rh = ribbon.offsetHeight;
      let x = vw * 0.30 + Math.sin(t * 0.15) * vw * 0.24 + Math.sin(t * 0.067) * vw * 0.06;
      let y = vh * 0.46 + Math.sin(t * 0.11 + 1.2) * vh * 0.24 + Math.cos(t * 0.05) * vh * 0.05;
      x = Math.max(12, Math.min(x, vw - rw - 12));
      y = Math.max(100, Math.min(y, vh - rh - 16));
      root.style.transform = `translate(${x}px, ${y}px)`;
      raf = requestAnimationFrame(drift);
    };
    if (reduce) root.style.transform = 'translate(20px, 100px)';
    else raf = requestAnimationFrame(drift);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) { if (raf) cancelAnimationFrame(raf); raf = 0; }
      else if (!reduce && !raf) raf = requestAnimationFrame(drift);
    });

    // ---------- effects ----------
    const COLORS = ['#ff5a5a', '#ff8a3d', '#ffd25a', '#ff3b6b', '#ffffff'];
    const floatPlus = (x, y) => {
      const el = document.createElement('div');
      el.className = 'gc-plus';
      el.style.left = x + 'px'; el.style.top = y + 'px';
      el.style.color = Math.random() < 0.28 ? '#ffd25a' : '#ff5a5a';
      el.innerHTML = svg() + '<span>+1</span>';
      fx.appendChild(el);
      const dx = (Math.random() - 0.5) * 80;
      el.animate([
        { transform: 'translate(-50%,-50%) scale(.5)', opacity: 0 },
        { transform: 'translate(-50%,-50%) scale(1.15)', opacity: 1, offset: .16 },
        { transform: `translate(calc(-50% + ${dx}px), calc(-50% - 130px)) scale(1)`, opacity: 0 }
      ], { duration: 1150, easing: 'cubic-bezier(.2,.7,.3,1)' }).onfinish = () => el.remove();
    };
    const burst = (x, y) => {
      for (let i = 0; i < 16; i++) {
        const p = document.createElement('div');
        p.className = 'gc-particle';
        const isHeart = Math.random() < 0.5;
        const size = isHeart ? 9 + Math.random() * 9 : 4 + Math.random() * 5;
        const col = COLORS[(Math.random() * COLORS.length) | 0];
        p.style.left = x + 'px'; p.style.top = y + 'px';
        p.style.width = size + 'px'; p.style.height = size + 'px';
        if (isHeart) { p.style.color = col; p.innerHTML = svg(); }
        else { p.style.background = col; p.style.boxShadow = `0 0 6px ${col}`; }
        fx.appendChild(p);
        const ang = Math.random() * Math.PI * 2;
        const dist = 55 + Math.random() * 95;
        const dx = Math.cos(ang) * dist;
        const dy = Math.sin(ang) * dist - 28;
        p.animate([
          { transform: 'translate(-50%,-50%) scale(1) rotate(0deg)', opacity: 1 },
          { transform: `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px)) scale(.15) rotate(${(Math.random() - .5) * 420}deg)`, opacity: 0 }
        ], { duration: 720 + Math.random() * 460, easing: 'cubic-bezier(.15,.6,.3,1)' }).onfinish = () => p.remove();
      }
    };
    let toastTimer = 0;
    const showToast = () => {
      const lang = ((window).__getLang && (window).__getLang()) || localStorage.getItem('site-lang') || 'en';
      const label = lang === 'zh' ? '次庆祝' : (likes === 1 ? 'celebration' : 'celebrations');
      toast.innerHTML = svg() + `<strong>${fmt(likes)}</strong> <span>${label}</span>`;
      toast.classList.add('gc-show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove('gc-show'), 2400);
    };

    const like = (ev) => {
      likes++;
      try { localStorage.setItem(CACHE, String(likes)); } catch (e) {}
      numEl.textContent = fmt(likes);
      numEl.classList.remove('gc-pop'); void numEl.offsetWidth; numEl.classList.add('gc-pop');
      const r = ribbon.getBoundingClientRect();
      const x = (ev && ev.clientX) ? ev.clientX : r.left + r.width / 2;
      const y = (ev && ev.clientY) ? ev.clientY : r.top + r.height / 2;
      if (!reduce) { floatPlus(x, y - 12); burst(x, y); }
      showToast();
      sendHit();
    };
    ribbon.addEventListener('click', like);
  }
</script>
